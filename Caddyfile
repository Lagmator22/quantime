# =====================================================================
# IICPC PLATFORM · CADDY EDGE
# ---------------------------------------------------------------------
# Serves the static frontend and reverse-proxies the API and WebSocket.
# Caddy auto-handles HTTP/2, gzip, and (in prod) Let's Encrypt.
# =====================================================================
:80 {
    encode gzip zstd

    # AI analysis endpoints route to ai-analyzer service
    handle /api/analyze {
        reverse_proxy ai-analyzer:7080
    }
    handle /api/report {
        reverse_proxy ai-analyzer:7080
    }

    # All other API + WebSocket routes go to gateway
    handle /api/* {
        reverse_proxy gateway:7070
    }
    handle /ws/* {
        reverse_proxy gateway:7070
    }

    # Static frontend
    handle {
        root * /srv
        try_files {path} {path}/index.html /index.html
        file_server
    }

    log {
        output stdout
        format console
    }
}
