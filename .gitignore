.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets / env
.env
.env.local
*.pem
*.key

# Frontend uploads (user-submitted artifacts; not source)
frontend/uploads/
uploads/

# Inspector screenshots from the design bundle
_inspect/
