# Copy to .env and adjust. docker-compose reads this automatically.

# Bind ports (host side). Change if you have something on 8080 already.
CADDY_PORT=8080
TSDB_PORT=5432
REDIS_PORT=6379
NATS_PORT=4222
NATS_MON_PORT=8222

# Bot fleet per-instance concurrency. Total bots = replicas × this.
# A laptop comfortably runs 4 replicas × 50 = 200 concurrent bots.
BOTS_PER_INSTANCE=50
